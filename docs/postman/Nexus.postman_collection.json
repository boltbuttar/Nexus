{
  "info": {
    "name": "Nexus API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{token}}", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Demo User\",\n  \"email\": \"demo@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"entrepreneur\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"demo@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"entrepreneur\"\n}"
            }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/change-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"password123\",\n  \"newPassword\": \"newpass123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users?role=investor"
          }
        },
        {
          "name": "Get User",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/users/me",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bio\": \"Updated bio\",\n  \"location\": \"Lahore\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Meetings",
      "item": [
        {
          "name": "List Meetings",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/meetings"
          }
        },
        {
          "name": "Create Meeting",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/meetings",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"participantId\": \"{{participantId}}\",\n  \"title\": \"Intro Call\",\n  \"startTime\": \"2026-05-30T10:00:00.000Z\",\n  \"endTime\": \"2026-05-30T10:30:00.000Z\"\n}"
            }
          }
        },
        {
          "name": "Update Meeting Status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/meetings/{{meetingId}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"accepted\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Documents",
      "item": [
        {
          "name": "List Documents",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/documents"
          }
        },
        {
          "name": "Upload Document",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/documents/upload",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file" }
              ]
            }
          }
        },
        {
          "name": "Upload Signature",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/documents/{{documentId}}/signature",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "signature", "type": "file" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Messages",
      "item": [
        {
          "name": "Conversations",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/messages/conversations"
          }
        },
        {
          "name": "Messages With User",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/messages/with/{{userId}}"
          }
        },
        {
          "name": "Send Message",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/messages",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"receiverId\": \"{{userId}}\",\n  \"content\": \"Hello from Postman\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Transactions",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/payments/transactions"
          }
        },
        {
          "name": "Deposit",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/payments/deposit",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 50,\n  \"currency\": \"USD\"\n}"
            }
          }
        },
        {
          "name": "Withdraw",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/payments/withdraw",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 25,\n  \"currency\": \"USD\"\n}"
            }
          }
        },
        {
          "name": "Transfer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/payments/transfer",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 15,\n  \"receiverId\": \"{{userId}}\",\n  \"currency\": \"USD\"\n}"
            }
          }
        }
      ]
    }
  ]
}
