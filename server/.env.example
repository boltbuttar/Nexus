# Backend environment variables
PORT=5000
MONGO_URI=mongodb://localhost:27017/nexus

# JWT security
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# Set to the deployed frontend URL (Vercel) in production.
CLIENT_ORIGIN=http://localhost:5173

# Email configuration (optional). Leave empty to use debug logging.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=notifications@nexus.local
EMAIL_DEBUG=true

# Stripe payments (optional)
STRIPE_SECRET=

# Uploads directory (local disk)
UPLOAD_DIR=uploads
